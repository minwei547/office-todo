# Supabase 项目 URL（Settings → API → Project URL）
VITE_SUPABASE_URL=https://你的项目id.supabase.co

# Supabase anon key（Settings → API → Project API keys → anon public）
VITE_SUPABASE_ANON_KEY=你的anon_key

# Web Push VAPID 公钥（运行 node scripts/gen-vapid.mjs 生成）
# 私钥请通过 supabase secrets set 配置到后端，切勿放在前端
VITE_VAPID_PUBLIC_KEY=你的_vapid_公钥

